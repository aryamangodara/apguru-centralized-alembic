# Database connection for Alembic migrations.
#
# Option 1 (preferred): a full sync SQLAlchemy URL.
# Note the +pymysql driver — Alembic uses the SYNC driver, not aiomysql.
DATABASE_URL=mysql+pymysql://user:password@your-db-host:3306/your_db_name

# Option 2: leave DATABASE_URL unset and compose from parts instead.
# (Mirrors the app's .env var names so you can reuse the same values.)
# DB_HOST=your-db-host
# DB_PORT=3306
# DB_USER=user
# DB_PASSWORD=password
# DB_NAME=your_db_name
